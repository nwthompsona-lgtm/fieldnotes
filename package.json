{
  "name": "fieldreport",
  "version": "0.1.0",
  "private": true,
  "description": "FieldReport — offline-first field-report capture for construction superintendents (pilot MVP).",
  "type": "module",
  "engines": {
    "node": ">=20.11"
  },
  "packageManager": "npm@10.9.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build:contracts": "npm run build -w @fieldreport/contracts",
    "build": "npm run build:contracts && npm run build -w @fieldreport/server && npm run build -w @fieldreport/capture && npm run build -w @fieldreport/web",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "dev:server": "npm run dev -w @fieldreport/server",
    "dev:capture": "npm run dev -w @fieldreport/capture",
    "dev:web": "npm run dev -w @fieldreport/web",
    "dryrun": "npm run dryrun -w @fieldreport/server"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
