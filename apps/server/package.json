{
  "name": "@fieldreport/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "dryrun": "tsx scripts/dryrun.ts",
    "seed": "tsx scripts/seed.ts",
    "db:init": "tsx scripts/db-init.ts",
    "verify:keys": "tsx scripts/verify-keys.ts",
    "tune": "tsx scripts/tune.ts",
    "clean:test": "tsx scripts/clean-test-data.ts",
    "e2e:live": "tsx scripts/e2e-live.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@deepgram/sdk": "^3.9.0",
    "@electric-sql/pglite": "^0.2.13",
    "@fastify/cors": "^9.0.1",
    "@fastify/multipart": "^8.3.0",
    "@fastify/static": "^7.0.4",
    "@fieldreport/contracts": "*",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.36.4",
    "fastify": "^4.28.1",
    "langsmith": "^0.2.5",
    "pg": "^8.13.1",
    "playwright": "1.61.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.33.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/pg": "^8.11.10",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
