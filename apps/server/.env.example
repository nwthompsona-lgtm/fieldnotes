# ───────────────────────────────────────────────────────────────────────────
# FieldReport server config. Copy to .env. With NOTHING set, the server runs fully
# locally: embedded pglite DB + local-disk storage + MOCK transcription + MOCK
# synthesis. Add the real keys below to switch on Deepgram + Claude.
# ───────────────────────────────────────────────────────────────────────────

PORT=8787
# Public base used in report links (set to your real https URL in prod).
PUBLIC_BASE_URL=http://localhost:8787

# ── Database ────────────────────────────────────────────────────────────────
# Unset => embedded pglite (dev). Set => prod Postgres (e.g. Neon).
# DATABASE_URL=postgres://user:pass@host/db?sslmode=require
# PGLITE_DIR=.data/pglite

# ── Object storage ──────────────────────────────────────────────────────────
# Unset S3_BUCKET => local-disk storage under .data/storage (dev).
# Set these for S3 / Cloudflare R2 (prod):
# S3_BUCKET=fieldreport-media
# S3_REGION=auto
# S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com   # R2 only; omit for AWS S3
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PUBLIC_BASE_URL=                                       # optional public/CDN base

# ── Transcription (Deepgram) ────────────────────────────────────────────────
# Unset => MOCK transcripts. Set => Deepgram Nova with keyterm biasing.
# DEEPGRAM_API_KEY=
# DEEPGRAM_MODEL=nova-2
# STT_LANGUAGE=en-US

# ── Synthesis (Claude) ──────────────────────────────────────────────────────
# Unset => MOCK synthesis. Set => Anthropic API.
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-8        # default; or claude-sonnet-4-6 for lower cost/latency
# ANTHROPIC_MAX_TOKENS=8192

# ── LangSmith tracing (optional) ────────────────────────────────────────────
# LANGCHAIN_TRACING_V2=true
# LANGSMITH_API_KEY=
# LANGCHAIN_PROJECT=fieldreport

# ── Admin ───────────────────────────────────────────────────────────────────
# Bearer token gating /api/admin/*. CHANGE THIS in prod.
ADMIN_TOKEN=dev-admin-token

# ── Pilot project (single super / single project) ───────────────────────────
PILOT_PROJECT_ID=pilot-project
PILOT_PROJECT_NAME=Watson Island
PILOT_SUPER_NAME=Pilot Super
