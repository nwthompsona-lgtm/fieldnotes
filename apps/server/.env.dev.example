# ───────────────────────────────────────────────────────────────────────────
# FieldReport server — DEV / STAGING env template (mirrors render.dev.yaml).
#
# This documents the env the dev Render service (fieldreport-server-dev, branch
# `develop`) expects. The DB and storage values here MUST be the dev Neon DB and
# the dev R2 bucket — NEVER the production ones. See DEV_ENV.md for the runbook.
#
# Locally you usually don't need any of this: with nothing set the server runs on
# pglite + local disk + mock STT/synthesis/email. This file is the reference for
# what to paste into the Render dev dashboard.
# ───────────────────────────────────────────────────────────────────────────

PORT=8787
# Auto-detected from RENDER_EXTERNAL_URL on Render; set only to override.
# PUBLIC_BASE_URL=https://fieldreport-server-dev.onrender.com

# ── DEV Database (separate Neon project/branch — NOT prod) ──────────────────
DATABASE_URL=postgres://user:pass@dev-host/fieldreport-dev?sslmode=require

# ── DEV Object storage (separate R2 bucket — NOT prod) ──────────────────────
S3_BUCKET=fieldreport-media-dev
S3_REGION=auto
S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ── Transcription / Synthesis (optional in dev: blank => MOCK) ──────────────
# DEEPGRAM_API_KEY=
# DEEPGRAM_MODEL=nova-3
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Admin break-glass token (DEV-only value, not the prod token) ────────────
ADMIN_TOKEN=dev-staging-admin-token

# ── Auth (Phase 1+) ─────────────────────────────────────────────────────────
SESSION_TTL_DAYS=0                 # 0 = indefinite sessions (D-2)

# ── CORS allowlist (Phase 0 parses it; Phase 3 enforces it) ─────────────────
# Comma-separated dev SPA origins. Leave UNSET to stay permissive (origin:true) so
# the dev SPAs can connect on first boot; set once the Vercel dev URLs exist:
# CORS_ALLOWED_ORIGINS=https://fieldreport-capture-dev.vercel.app,https://fieldreport-web-dev.vercel.app

# ── Email (Phase 5+): blank RESEND_API_KEY => MOCK email driver ─────────────
# RESEND_API_KEY=
EMAIL_FROM=FieldReport (dev) <reports@fieldreport.app>
# Invite-accept links point at the web-dev app:
# WEB_BASE_URL=https://fieldreport-web-dev.vercel.app

# ── Pilot org + admin bootstrap for the DEV tenant (Phase 4 seed) ───────────
PILOT_ORG_ID=org_pilot_dev
PILOT_ORG_NAME=Watson Builders (dev)
PILOT_PROJECT_NAME=Watson Island
PILOT_SUPER_NAME=Pilot Super
# PILOT_SUPER_EMAIL=you@example.com
# PILOT_SUPER_PASSWORD=             # one-time first-login password; rotate after
