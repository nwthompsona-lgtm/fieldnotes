# FieldReport CAPTURE — DEV / STAGING env template.
# Set these on the Vercel "capture-dev" project (production branch = develop).
# VITE_* are baked at build time, so redeploy if the dev server URL changes.

# Base URL of the DEV upload server (Render fieldreport-server-dev).
VITE_API_BASE=https://fieldreport-server-dev.onrender.com

# DEV web app base, so capture can link to the review page after Sync.
VITE_WEB_BASE=https://fieldreport-web-dev.vercel.app
