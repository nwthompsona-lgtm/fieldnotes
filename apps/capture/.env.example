# FieldReport CAPTURE — environment config.
# Copy to `.env` (or `.env.local`) and adjust. These are baked at build time.

# Base URL of the upload server. Default targets the local dev server.
VITE_API_BASE=http://localhost:8787

# Project this capture client is bound to (stamped into the upload manifest).
VITE_PROJECT_ID=pilot-project

# Display + manifest super name (stamped into the upload manifest).
VITE_SUPER_NAME=Pilot Super
